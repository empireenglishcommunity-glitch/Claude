# ─────────────────────────────────────────────────────────────────────────────
# Empire English — environment configuration template
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# Public Supabase config — SAFE to ship in the app bundle.
# The anon key is protected by Row-Level Security; it grants no privileged
# access on its own. Variables prefixed EXPO_PUBLIC_ are inlined by Expo.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY SECRETS — never commit these and never expose them to the app.
# Set them as Supabase Edge Function secrets (e.g. `supabase secrets set ...`).
# They are listed here for documentation only; do NOT put real values in .env
# that ships with the client.
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=server-only-do-not-ship
# AI provider keys (Speech + Language engines) live ONLY in Edge Function
# secrets — see supabase/functions/README.md. Examples:
# AZURE_SPEECH_KEY=server-only
# SPEECHACE_API_KEY=server-only
# OPENAI_API_KEY=server-only
# ANTHROPIC_API_KEY=server-only
