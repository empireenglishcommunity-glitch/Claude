{
  "expo": {
    "name": "Empire English Community",
    "slug": "empire-english",
    "version": "1.0.0",
    "scheme": "empire",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0B0B",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0B0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maclempire.empireenglish",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Empire English uses your microphone for pronunciation practice (Shadowing)."
      }
    },
    "android": {
      "package": "com.maclempire.empireenglish",
      "permissions": ["android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0B",
        "foregroundImage": "./assets/logo.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Empire English uses your microphone for pronunciation practice (Shadowing)."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Empire English uses your photos so you can set a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
