# Copy this file to ".dev.vars" for local `wrangler dev`, OR set these as
# Worker secrets in production (npx wrangler secret put NAME).
# NEVER commit real values. ".dev.vars" is gitignored.

# Telegram bot token from @BotFather
TELEGRAM_TOKEN=put-your-telegram-bot-token-here

# Your personal Telegram chat id from @userinfobot (you must press Start on your bot)
ADMIN_CHAT_ID=123456789

# Gemini API key from https://aistudio.google.com/apikey  (free tier, no card)
GEMINI_API_KEY=put-your-gemini-api-key-here

# OPTIONAL secondary fallback LLM, free, from https://console.groq.com
GROQ_API_KEY=
