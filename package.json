{
  "name": "empire-english-community",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "setup": "expo install expo-router expo-linking expo-constants expo-status-bar expo-system-ui expo-speech expo-linear-gradient @react-native-async-storage/async-storage react-native-safe-area-context react-native-screens react-native-gesture-handler @expo/vector-icons && expo install --fix",
    "start": "expo start",
    "tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "fix": "expo install --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --ci",
    "test:unit": "jest --ci __tests__/unit",
    "test:property": "jest --ci __tests__/property",
    "test:integration": "jest --ci __tests__/integration"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "^56.0.0",
    "expo-av": "^16.0.8",
    "expo-constants": "^56.0.18",
    "expo-linear-gradient": "^56.0.4",
    "expo-linking": "^56.0.14",
    "expo-localization": "^56.0.6",
    "expo-router": "^56.2.11",
    "expo-speech": "^56.0.3",
    "expo-status-bar": "^56.0.4",
    "expo-system-ui": "^56.0.5",
    "i18next": "^23.16.8",
    "react": "^19.2.3",
    "react-dom": "^19.2.7",
    "react-i18next": "^14.1.3",
    "react-native": "^0.85.0",
    "react-native-gesture-handler": "^3.0.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native/jest-preset": "^0.85.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "babel-preset-expo": "^56.0.15",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "react-server-dom-webpack": "~19.2.4",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.0"
  }
}
